# Copy this to .env and fill in OPENROUTER_API_KEY.

# The brain. ONE key for every model. Get it at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Model slug (any OpenRouter model). FREE options first — all support tool-calling.
# FREE (rate-limited ~50/day under $10 credit, ~1000/day if you hold $10):
#   nvidia/nemotron-3-super-120b-a12b:free  <- smart + fast, 1M ctx   [default]
#   nvidia/nemotron-3-ultra-550b-a55b:free  <- smartest free, a bit slower
#   nvidia/nemotron-3-nano-30b-a3b:free     <- fastest free replies
#   meta-llama/llama-3.3-70b-instruct:free  <- solid all-rounder
# PAID (cheap, no daily cap — pennies):
#   google/gemini-2.5-flash-lite  <- $0.10/$0.40 per M, basically free at chat volume
#   google/gemini-2.5-flash       <- $0.30/$2.50, fast + smart
#   anthropic/claude-sonnet-4.6   <- $3/$15, top quality when it matters
MODEL=nvidia/nemotron-3-super-120b-a12b:free

# Optional: only reply to these numbers while testing (comma-separated, country code, no +).
# Leave blank to reply to everyone who messages you.
ALLOWLIST=

# Agent persona name (also edit SYSTEM_PROMPT in agent.js for real personality).
AGENT_NAME=Zumi
